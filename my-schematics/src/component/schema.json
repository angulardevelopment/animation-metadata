{
  "$schema": "http://json-schema.org/schema",
  "$id": "customComponent",
  "title": "Custom Component Options",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Component name"
    },
    "path": {
      "type": "string",
      "default": "src/app"
    }
  },
  "required": ["name"]
}